# =====================================================
# Database (PostgreSQL via docker-compose.yml)
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_gmi2
DB_USERNAME=postgres
DB_PASSWORD=postgres

# =====================================================
# JWT (cambia JWT_SECRET en producción — mínimo 32 chars)
# =====================================================
JWT_SECRET=CHANGE-ME-min-32-chars
JWT_EXPIRATION=300
JWT_REFRESH_EXPIRATION=604800

# =====================================================
# MercadoPago (Checkout Pro)
# Panel: https://www.mercadopago.com.pe/developers/panel/app
#
# IMPORTANTE: usá credenciales TEST primero, en producción cambialas a APP_USR-
#   - Test: empieza con TEST-...
#   - Prod: empieza con APP_USR-...
# =====================================================

# Backend → MP API (privado)
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxx-xxxxxxxxx

# Webhook signing key (panel → tu app → Webhooks → "Configurar notificaciones" → genera secret)
MERCADOPAGO_WEBHOOK_SECRET=tu-webhook-secret

# URL pública del backend donde MP manda los webhooks (Railway, ngrok para local, etc.)
# DEBE ser HTTPS. En local usar ngrok: `ngrok http 3000`
MERCADOPAGO_WEBHOOK_URL=https://tu-backend.up.railway.app/webhooks/mercadopago

# URLs del frontend storefront a las que MP redirige tras el pago
# DEBEN ser HTTPS en producción (localhost OK solo para test local)
MERCADOPAGO_SUCCESS_URL=https://tu-storefront.vercel.app/payment/success
MERCADOPAGO_FAILURE_URL=https://tu-storefront.vercel.app/payment/failure
MERCADOPAGO_PENDING_URL=https://tu-storefront.vercel.app/payment/pending

# =====================================================
# Google OAuth (login con Google)
# =====================================================
GOOGLE_CLIENT_ID=your-google-client-id

# =====================================================
# Cloudinary (uploads de imágenes de productos)
# Panel: https://cloudinary.com/console
# =====================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# =====================================================
# Elasticsearch (logs + búsqueda)
# =====================================================
ELASTICSEARCH_NODE=http://localhost:9200

# =====================================================
# Email SMTP (notificaciones de orden)
# Para Gmail: usá App Password, no tu contraseña real
# https://myaccount.google.com/apppasswords
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tienda@gmail.com
SMTP_PASS=app-password
EMAIL_FROM="Mi Tienda <tienda@gmail.com>"

# =====================================================
# Orders (lógica de negocio)
# =====================================================
ORDER_EXPIRATION_HOURS=2
SHIPPING_STANDARD_COST=1500
SHIPPING_EXPRESS_COST=3000
SHIPPING_PICKUP_COST=0

# =====================================================
# App
# =====================================================
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
